# Copy this file to .env and fill in real values before running the app.
# .env must NEVER be committed to version control — it is listed in .gitignore.

# ---------------------------------------------------------------------------
# SECRET_KEY — REQUIRED. Must be replaced with a real random value.
#
# This key signs Flask session cookies. If it is weak or shared, an attacker
# can forge session cookies and impersonate any user.
#
# Generate a secure value by running this command in your terminal:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Copy the output (a 64-character hex string) and paste it as the value below.
# Never use the placeholder string below in production or share this value.
# ---------------------------------------------------------------------------
SECRET_KEY=REPLACE-THIS-with-output-of-secrets.token_hex-32

# ---------------------------------------------------------------------------
# DATABASE_URL — optional for local development.
# Defaults to a local SQLite file (support.db) if not set.
# On Render this is injected automatically from the linked PostgreSQL database.
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///support.db

# ---------------------------------------------------------------------------
# SESSION_COOKIE_SECURE
# Set to false for local development (HTTP).
# Set to true only when the app is served over HTTPS (e.g. on Render).
# ---------------------------------------------------------------------------
SESSION_COOKIE_SECURE=false

# ---------------------------------------------------------------------------
# FLASK_DEBUG
# Set to 1 to enable the interactive debugger and auto-reloader locally.
# Must be 0 in production — the debugger exposes a remote code execution risk.
# ---------------------------------------------------------------------------
FLASK_DEBUG=1

# ---------------------------------------------------------------------------
# ADMIN_REGISTRATION_CODE — REQUIRED to enable admin account creation.
#
# This is the secret code your admins must type when registering. Without it,
# /register/admin redirects to the home page immediately (self-registration
# is disabled).
#
# Choose any strong, memorable value — it does not need to be a hex string.
# Example (do NOT use this exact value):
#   python -c "import secrets; print(secrets.token_hex(16))"
#
# LOCAL .env:  set it to whatever value you will give your admins.
# RENDER:      do NOT put this in render.yaml. After deploying, go to:
#              Render Dashboard → your Web Service → Environment →
#              ADMIN_REGISTRATION_CODE → enter your chosen value → Save Changes.
#              Render will redeploy automatically.
# ---------------------------------------------------------------------------
ADMIN_REGISTRATION_CODE=
