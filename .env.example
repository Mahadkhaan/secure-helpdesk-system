# Copy this file to .env and fill in real values.
# .env must NEVER be committed to version control.

# Required: generate with `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=replace-with-a-long-random-string

# Optional: defaults to SQLite for local dev
DATABASE_URL=sqlite:///support.db

# Set to true only when serving over HTTPS (production)
SESSION_COOKIE_SECURE=false

# Flask built-in: set to 1 for debug mode locally, never in production
FLASK_DEBUG=0

# Required to enable /register/admin. Leave empty to disable admin self-registration entirely.
# Generate a strong value: python -c "import secrets; print(secrets.token_hex(16))"
ADMIN_REGISTRATION_CODE=
