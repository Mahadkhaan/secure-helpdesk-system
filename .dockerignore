# Secrets — never bake into the image
.env

# Version control
.git/
.github/

# Python cache
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
venv/
.venv/
env/
.env/

# Databases — mount a volume instead
*.db
*.sqlite
*.sqlite3
instance/

# Logs — written at runtime
logs/*.log
logs/*.log.*

# Test artefacts
.pytest_cache/
.coverage
htmlcov/
coverage.xml
tests/

# IDE / OS noise
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# Build outputs
dist/
build/
*.egg-info/
